# --- PRODUCTION (Postmark) ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.postmarkapp.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-postmark-server-api-token
DJANGO_EMAIL_HOST_PASSWORD=your-postmark-server-api-token
DJANGO_DEFAULT_FROM_EMAIL=Missionary Calendar <verified-sender@yourdomain.com>

# Missionary Notifications
MISSIONARY_EMAIL=missionaries@example.com

# Ward/Branch title
WARD_TITLE="Ward"

# Unavailable Days
# Comma-separated rules for days that default to unavailable on the calendar.
# Day names: mon,tue/tues,wed,thu/thurs,fri,sat,sun (full names also accepted)
# Week-of-month qualifiers: day:1/3 (specific weeks), day:odd, day:even
# Examples:
#   UNAVAILABLE_DAYS=mon              -> every Monday
#   UNAVAILABLE_DAYS=mon,fri          -> every Monday and Friday
#   UNAVAILABLE_DAYS=mon:1/3          -> Mondays in the 1st and 3rd weeks
#   UNAVAILABLE_DAYS=mon:even         -> Mondays in even weeks (2nd, 4th)
#   UNAVAILABLE_DAYS=mon,tue:2/4      -> every Monday + Tuesdays in weeks 2 & 4
#   UNAVAILABLE_DAYS=week:3/4/5       -> all days in weeks 3, 4, 5 unavailable
#   UNAVAILABLE_DAYS=week:even        -> all days in even weeks unavailable
#   UNAVAILABLE_DAYS=mon,week:3/4/5   -> Mondays + full weeks 3-5 unavailable
#   UNAVAILABLE_DAYS=                 -> no days are unavailable
UNAVAILABLE_DAYS=
