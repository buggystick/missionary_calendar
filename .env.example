# Django Core Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=missionaries.farmingtonward.church,localhost

# --- POSTMARK CONFIGURATION ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.postmarkapp.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True

# For TESTING (Sandbox): Use your Postmark Sandbox Server API Token
# For PRODUCTION: Use your Postmark Production Server API Token
DJANGO_EMAIL_HOST_USER=your-postmark-token
DJANGO_EMAIL_HOST_PASSWORD=your-postmark-token

# Postmark requires a verified sender signature
DJANGO_DEFAULT_FROM_EMAIL=Missionary Calendar <verified-sender@yourdomain.com>

# Missionary Notifications
MISSIONARY_EMAIL=missionaries@example.com
